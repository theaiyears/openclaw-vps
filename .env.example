# Public URL used for sitemap + canonical links
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional plausible analytics (leave unset if not configured yet)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# Token gate for metrics API/dashboard
METRICS_TOKEN=replace-with-random-secret

# Optional Supabase event storage (recommended for production on Vercel)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_EVENTS_TABLE=events

# Optional monetization links (leave unset to hide each slot)
# Software category
# NEXT_PUBLIC_OFFER_SOFTWARE_1_URL=https://example.com/offer-1
# NEXT_PUBLIC_OFFER_SOFTWARE_2_URL=https://example.com/offer-2

# Education category
# NEXT_PUBLIC_OFFER_EDUCATION_1_URL=https://example.com/offer-3
# NEXT_PUBLIC_OFFER_EDUCATION_2_URL=https://example.com/offer-4

# Creator tools category
# NEXT_PUBLIC_OFFER_CREATOR_TOOLS_1_URL=https://example.com/offer-5
# NEXT_PUBLIC_OFFER_CREATOR_TOOLS_2_URL=https://example.com/offer-6
